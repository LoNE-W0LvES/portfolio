{
  "crons": [
    {
      "path": "/api/cron/keep-alive",
      "schedule": "0 0 */4 * *"
    }
  ],
  "rewrites": [
    { "source": "/donate", "destination": "/api/donate" },
    { "source": "/donation", "destination": "/api/donate" },
    {
      "source": "/((?!api(?:/|$)).*)",
      "destination": "/index.html"
    }
  ]
}
